{
  "name": "multivariate-wizards",
  "version": "1.0.0",
  "private": true,
  "description": "Multivariate Wizards — a fill-in-the-blank wizard duel built from an 18-year exam bank.",
  "type": "module",
  "scripts": {
    "import:questions": "tsx scripts/importQuestions.ts",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build --config client/vite.config.ts",
    "start": "tsx server/src/index.ts",
    "audit:questions": "tsx scripts/auditQuestionAnswers.ts",
    "audit:translations": "tsx scripts/auditQuestionTranslations.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "phaser": "^3.80.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "mammoth": "^1.8.0",
    "vite": "^5.3.3"
  }
}